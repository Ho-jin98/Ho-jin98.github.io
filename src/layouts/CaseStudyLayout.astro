---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { projects } from '../data/portfolio';
import { caseStudies } from '../data/caseStudies';

interface Props {
  project: (typeof projects)[number];
}

const { project } = Astro.props;
const caseStudy = caseStudies[project.slug];
const showGenericGithub = project.slug !== 'hankkipot' && project.slug !== 'k-server' && Boolean(project.github);

if (!caseStudy) {
  throw new Error(`Case study content is missing for "${project.slug}".`);
}

const splitLead = (lead: string, accent?: string | string[]) => {
  const accents = accent ? (Array.isArray(accent) ? accent : [accent]) : [];
  if (accents.length === 0) return [{ text: lead, accent: false }];

  const pattern = new RegExp(
    `(${accents.map((item) => item.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')).join('|')})`,
    'g',
  );

  return lead
    .split(pattern)
    .filter(Boolean)
    .map((text) => ({ text, accent: accents.includes(text) }));
};

const highlightTerms = [
  'placeName, placeLat, placeLng',
  '최종 인증 성공 여부',
  'Geolocation API',
  '서버 거리 검증',
  'Kakao Maps',
  '서버 검증',
  '인증 화면',
  '좌표 흐름',
];

const highlightPattern = new RegExp(
  `(${highlightTerms.map((item) => item.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')).join('|')})`,
  'g',
);

const highlightTextParts = (text: string) =>
  text
    .split(highlightPattern)
    .filter(Boolean)
    .map((text) => ({ text, highlight: highlightTerms.includes(text) }));
---

<BaseLayout
  title={`${project.title} Case Study — 정호진`}
  description={caseStudy.description ??
    `${project.title} 프로젝트에서 다룬 문제, 판단, 구현 흐름과 결과를 정리한 케이스 스터디입니다.`}
  bodyClass={`document-page case-study-page case-study-page--${project.slug}`}
>
  <SiteHeader />

  <main
    class:list={['case-study', `case-study--${project.slug}`]}
    data-case-deck
    data-scroll-mode={project.slug === 'hankkipot' || project.slug === 'k-server' ? 'chapter' : 'section'}
  >
    <h1 class="sr-only">{project.title} 케이스 스터디</h1>

    <div class="case-study__body">
      <nav class="case-study__toc" aria-label={`${project.title} 케이스 스터디 목차`}>
        <a class:list={['case-study__back', (project.slug === 'hankkipot' || project.slug === 'k-server') && 'magnetic']} href={`/#${project.slug}`}>← 프로젝트 목록으로</a>
        {project.slug === 'hankkipot' && (
          <div class="case-study__project">
            <div class="case-study__project-logo" aria-hidden="true">
              <span>한끼</span>
              <strong>POT</strong>
            </div>
            <div class="case-study__project-copy">
              <strong>한끼팟</strong>
              <p>대학생 식사 매칭 서비스</p>
            </div>
          </div>
        )}
        {project.slug !== 'hankkipot' && (
          <div class="case-study__project case-study__project--compact">
            <div class="case-study__project-logo" aria-hidden="true">
              {project.slug === 'k-server' ? (
                <strong>K</strong>
              ) : (
                <>
                  <span>{project.name.slice(0, 2)}</span>
                  <strong>{project.projectNumber.padStart(2, '0')}</strong>
                </>
              )}
            </div>
            <div class="case-study__project-copy">
              <strong>{project.title}</strong>
              <p>{project.slug === 'k-server' ? '다중 인스턴스 커피 주문 시스템' : project.subtitle}</p>
            </div>
          </div>
        )}
        <p>{project.slug === 'hankkipot' || project.slug === 'k-server' ? '프로젝트 단계' : 'Case Study'}</p>
        {project.slug === 'k-server' ? (
          <div class="case-study__toc-steps">
            {caseStudy.sections.map((section, index) => (
              <a
                href={`#${section.id}`}
                class={index === 0 ? 'is-active' : undefined}
                data-toc-link
              >
                <span>{section.number}</span>
                {section.navSubtitle ? (
                  <span class="case-study__toc-label">
                    <strong>{section.navTitle}</strong>
                    <small>{section.navSubtitle}</small>
                  </span>
                ) : (
                  section.navTitle
                )}
              </a>
            ))}
          </div>
        ) : (
          caseStudy.sections.map((section, index) => (
            <a
              href={`#${section.id}`}
              class={index === 0 ? 'is-active' : undefined}
              data-toc-link
            >
              <span>{section.number}</span>
              {section.navSubtitle ? (
                <span class="case-study__toc-label">
                  <strong>{section.navTitle}</strong>
                  <small>{section.navSubtitle}</small>
                </span>
              ) : (
                section.navTitle
              )}
            </a>
          ))
        )}
        {project.slug === 'hankkipot' && (
          <a
            class="case-study__github magnetic"
            href="https://github.com/Team3-Final-Project-SNS/Final-project"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="case-study__github-text">
              <span>한끼팟</span>
              <span>GITHUB 보러가기</span>
            </span>
            <span aria-hidden="true">↗</span>
          </a>
        )}
        {project.slug === 'k-server' && (
          <a
            class="case-study__github case-study__github--compact magnetic"
            href="https://github.com/Ho-jin98/k-server-project"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="case-study__github-text">
              <span>K-Server</span>
              <span>GITHUB 보러가기</span>
            </span>
            <span aria-hidden="true">↗</span>
          </a>
        )}
        {showGenericGithub && (
          <a
            class="case-study__github case-study__github--compact magnetic"
            href={project.github}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="case-study__github-text">
              <span>GITHUB</span>
              <span>보러가기</span>
            </span>
            <span aria-hidden="true">↗</span>
          </a>
        )}
        {project.slug !== 'hankkipot' && project.slug !== 'k-server' && (
          <small>
            <span data-case-progress>01</span> / {String(caseStudy.sections.length).padStart(2, '0')}
          </small>
        )}
      </nav>

      <div class="case-study__content">
        {
          caseStudy.sections.map((section, index) => {
            const leadParts = splitLead(section.lead, section.accent);

            return (
              <section
                id={section.id}
                class:list={['case-section', index === 0 && 'is-active']}
                data-case-section
                aria-labelledby={`${section.id}-title`}
              >
                <div class="case-section__inner">
                  <header class="case-section__heading">
                    <h2 id={`${section.id}-title`}>
                      {leadParts.map((part) => part.accent ? <em>{part.text}</em> : part.text)}
                    </h2>
                  </header>

                  {section.content && (
                    <div class="case-content-stack">
                      {section.content.map((block) => (
                        <>
                          {block.type === 'hero' && (
                            project.slug === 'hankkipot' ? (
                              <div class="hankki-overview">
                                <div class="hankki-overview__hero">
                                  <div class="hankki-overview__copy">
                                    <span class="hankki-overview__badge">한끼팟 · 만남 인증</span>
                                    <h3>
                                      장소 인증과 QR 만남 인증을<br />
                                      서비스 완료 흐름으로 연결했습니다.
                                    </h3>
                                    <div class="hankki-overview__prose">
                                      {block.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
                                    </div>
                                    <ul class="hankki-overview__chips" aria-label="한끼팟 핵심 구현 범위">
                                      {block.scope.map((item) => <li>{item}</li>)}
                                    </ul>
                                  </div>

                                  <figure class="hankki-overview__visual">
                                    <img
                                      src="/hankkipot-verification-hero.png"
                                      alt="GPS 장소 인증과 QR 대면 인증을 연결한 흐름"
                                    />
                                    <span class="is-gps">GPS 장소 인증</span>
                                    <span class="is-qr">QR 만남 인증</span>
                                  </figure>
                                </div>

                                <div class="hankki-summary-cards">
                                  <article>
                                    <i aria-hidden="true">◎</i>
                                    <div>
                                      <span>Kakao Maps GPS 인증</span>
                                      <p>약속 장소와 현재 위치를 지도에 표시하고, 서버 거리 검증으로 장소 인증 여부를 판단하도록 연결했습니다.</p>
                                    </div>
                                  </article>
                                  <article>
                                    <i aria-hidden="true">⌁</i>
                                    <div>
                                      <span>QR 만남 인증</span>
                                      <p>등록자는 QR을 표시하고 신청자는 스캔하는 구조로, GPS 이후 실제 대면 여부를 검증했습니다.</p>
                                    </div>
                                  </article>
                                  <article>
                                    <i aria-hidden="true">♙</i>
                                    <div>
                                      <span>신청자별 완료 흐름</span>
                                      <p>QR 인증 결과가 각 Match 완료, 위치 데이터 삭제, 책임비 반환과 후속 상태 처리로 이어지도록 구성했습니다.</p>
                                    </div>
                                  </article>
                                </div>

                              </div>
                            ) : (
                              <div class="case-overview-hero">
                                <div class="case-overview-hero__copy">
                                  <span class="case-overview-hero__label">{block.label}</span>
                                  <div class="case-overview-hero__prose">
                                    {block.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
                                  </div>
                                  <ul class="case-overview-hero__scope">
                                    {block.scope.map((item) => <li>{item}</li>)}
                                  </ul>
                                </div>
                              </div>
                            )
                          )}

                          {block.type === 'prose' && (
                            <div class="case-prose">
                              {block.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
                            </div>
                          )}

                          {block.type === 'facts' && (
                            <dl class="case-facts">
                              {block.items.map((fact) => (
                                <div>
                                  <dt>{fact.label}</dt>
                                  <dd>{fact.value}</dd>
                                </div>
                              ))}
                            </dl>
                          )}

                          {block.type === 'scope' && (
                            <div class="case-scope">
                              <span>{block.label}</span>
                              <p>{block.text}</p>
                            </div>
                          )}

                          {block.type === 'flow' && (
                            <ol class="case-flow" aria-label={`${section.title} 처리 흐름`}>
                              {block.items.map((step, flowIndex) => (
                                <li>
                                  <span>{String(flowIndex + 1).padStart(2, '0')}</span>
                                  <strong>{step}</strong>
                                </li>
                              ))}
                            </ol>
                          )}

                          {block.type === 'flowGroups' && (
                            <div class="case-flow-groups" aria-label={`${section.title} 처리 흐름`}>
                              {block.groups.map((group) => (
                                <article>
                                  <span>{group.label}</span>
                                  <h3>{group.title}</h3>
                                  <ol>
                                    {group.items.map((step, groupIndex) => (
                                      <li>
                                        <i>{String(groupIndex + 1).padStart(2, '0')}</i>
                                        <strong>{step}</strong>
                                      </li>
                                    ))}
                                  </ol>
                                </article>
                              ))}
                            </div>
                          )}

                          {block.type === 'approach' && (
                            <div class="case-approach">
                              <div class="case-approach__timeline">
                                <span>{project.slug === 'k-server' ? '처리 흐름' : '인증 흐름'}</span>
                                <ol>
                                  {block.steps.map((step, stepIndex) => (
                                    <li>
                                      <i>{String(stepIndex + 1).padStart(2, '0')}</i>
                                      <strong>{step}</strong>
                                    </li>
                                  ))}
                                </ol>
                              </div>
                              <div class="case-approach__cards">
                                {block.items.map((item, itemIndex) => (
                                  <article class:list={[item.tone && `case-story-card--${item.tone}`]}>
                                    <i aria-hidden="true">{String(itemIndex + 1).padStart(2, '0')}</i>
                                    <span>{item.label}</span>
                                    <p>{item.text}</p>
                                  </article>
                                ))}
                              </div>
                            </div>
                          )}

                          {block.type === 'comparison' && (
                            <div class="case-comparison">
                              <table>
                                <thead>
                                  <tr>
                                    <th scope="col">비교 항목</th>
                                    {block.columns.map((column, columnIndex) => (
                                      <th
                                        scope="col"
                                        class={columnIndex === block.highlightColumn ? 'is-highlighted' : undefined}
                                      >
                                        {column}
                                      </th>
                                    ))}
                                  </tr>
                                </thead>
                                <tbody>
                                  {block.rows.map((row) => (
                                    <tr>
                                      <th scope="row">{row.label}</th>
                                      {row.values.map((value, columnIndex) => (
                                        <td class={columnIndex === block.highlightColumn ? 'is-highlighted' : undefined}>
                                          {value}
                                        </td>
                                      ))}
                                    </tr>
                                  ))}
                                </tbody>
                              </table>
                            </div>
                          )}

                          {block.type === 'accordion' && (
                            <div class="case-accordions">
                              {block.items.map((item) => (
                                <details>
                                  <summary>
                                    <span>{item.title}</span>
                                    <i aria-hidden="true">+</i>
                                  </summary>
                                  <div class="case-accordion__body">
                                    {item.text && <p>{item.text}</p>}
                                    {item.cards && (
                                      <div class="case-accordion__cards">
                                        {item.cards.map((card) => (
                                          <article>
                                            <strong>{card.label}</strong>
                                            <p>{card.text}</p>
                                          </article>
                                        ))}
                                      </div>
                                    )}
                                    {item.facts && (
                                      <dl class="case-accordion__facts">
                                        {item.facts.map((fact) => (
                                          <div>
                                            <dt>{fact.label}</dt>
                                            <dd>{fact.value}</dd>
                                          </div>
                                        ))}
                                      </dl>
                                    )}
                                  </div>
                                </details>
                              ))}
                            </div>
                          )}

                          {block.type === 'decision' && (
                            <div class="case-decision">
                              <article>
                                <span>{block.from.label}</span>
                                <p>{block.from.text}</p>
                              </article>
                              <i aria-hidden="true">→</i>
                              <article>
                                <span>{block.to.label}</span>
                                <p>{block.to.text}</p>
                              </article>
                            </div>
                          )}

                          {block.type === 'states' && (
                            <dl class="case-states">
                              {block.items.map((state) => (
                                <div>
                                  <dt>{state.label}</dt>
                                  <dd>{state.value}</dd>
                                </div>
                              ))}
                            </dl>
                          )}

                          {block.type === 'cards' && (
                            <div class="case-content-group" data-block-label={block.label}>
                              {block.label && <h3>{block.label}</h3>}
                              <div
                                class:list={[
                                  'case-blocks',
                                  'case-story-cards',
                                  `case-story-cards--${block.columns ?? 4}`,
                                ]}
                              >
                                {block.items.map((item) => (
                                  <article class:list={[item.tone && `case-story-card--${item.tone}`]}>
                                    <span>{item.label}</span>
                                    <p>{item.text}</p>
                                  </article>
                                ))}
                              </div>
                            </div>
                          )}

                          {block.type === 'metrics' && (
                            <div class="case-content-group">
                              {block.label && <h3>{block.label}</h3>}
                              <div class="case-metrics">
                                {block.items.map((metric) => (
                                  <article class:list={[metric.tone && `case-metric--${metric.tone}`]}>
                                    <span>{metric.label}</span>
                                    <strong>{metric.value}</strong>
                                    {metric.note && <small>{metric.note}</small>}
                                  </article>
                                ))}
                              </div>
                            </div>
                          )}

                          {block.type === 'subsection' && (
                            <header class="case-subsection">
                              {block.label && <span>{block.label}</span>}
                              <h3>{block.title}</h3>
                              {block.text && <p>{block.text}</p>}
                            </header>
                          )}

                          {block.type === 'feature' && (
                            <div class="case-feature">
                              <div class="case-feature__copy">
                                {block.label && <span>{block.label}</span>}
                                <h3>{block.title}</h3>
                                <div class="case-feature__cards">
                                  {block.items.map((item) => (
                                    <article class:list={[item.tone && `case-story-card--${item.tone}`]}>
                                      <strong>{item.label}</strong>
                                      <p>{item.text}</p>
                                    </article>
                                  ))}
                                </div>
                              </div>
                              <figure class="case-evidence">
                                <div class="case-evidence__frame" aria-hidden="true">
                                  <i></i>
                                  <i></i>
                                  <i></i>
                                </div>
                                <figcaption>
                                  <strong>{block.evidence.label}</strong>
                                  {block.evidence.caption && <span>{block.evidence.caption}</span>}
                                </figcaption>
                              </figure>
                            </div>
                          )}

                          {block.type === 'evidence' && (
                            <div class="case-content-group">
                              {block.label && <h3>{block.label}</h3>}
                              <div class="case-evidence-grid">
                                {block.items.map((item) => (
                                  <figure class="case-evidence">
                                    <div class="case-evidence__frame" aria-hidden="true">
                                      <i></i>
                                      <i></i>
                                      <i></i>
                                    </div>
                                    <figcaption>
                                      <strong>{item.label}</strong>
                                      {item.caption && <span>{item.caption}</span>}
                                    </figcaption>
                                  </figure>
                                ))}
                              </div>
                            </div>
                          )}

                          {block.type === 'proofs' && (
                            <div class="case-content-group case-proof-summary" data-block-label={block.label}>
                              {block.label && <h3>{block.label}</h3>}
                              <div class="case-proof-grid">
                                {block.items.map((item) => (
                                  <article>
                                    <figure>
                                      <img src={item.image.src} alt={item.image.alt} loading="lazy" />
                                    </figure>
                                    <div>
                                      <h4>{item.title}</h4>
                                      <p>{item.text}</p>
                                      <dl>
                                        {item.items.map((fact) => (
                                          <div>
                                            <dt>{fact.label}</dt>
                                            <dd>{fact.value}</dd>
                                          </div>
                                        ))}
                                      </dl>
                                    </div>
                                  </article>
                                ))}
                              </div>
                            </div>
                          )}

                          {block.type === 'hierarchy' && (
                            <div class="case-hierarchy">
                              {block.label && <span class="case-hierarchy__label">{block.label}</span>}
                              <strong class="case-hierarchy__parent">{block.parent}</strong>
                              <div class="case-hierarchy__children">
                                {block.items.map((item) => (
                                  <article class:list={[item.tone && `is-${item.tone}`]}>
                                    <span>{item.label}</span>
                                    <strong>{item.value}</strong>
                                  </article>
                                ))}
                              </div>
                              <p>{block.footer}</p>
                            </div>
                          )}

                          {block.type === 'tabs' && (
                            <div class="case-tabs" data-case-tabs>
                              <div class="case-tabs__list" role="tablist" aria-label={`${section.navTitle} 상세`}>
                                {block.tabs.map((tab, tabIndex) => (
                                  <button
                                    id={`${section.id}-${tab.id}-tab`}
                                    class:list={[project.slug === 'readys7' && 'magnetic']}
                                    type="button"
                                    role="tab"
                                    aria-controls={`${section.id}-${tab.id}-panel`}
                                    aria-selected={tabIndex === 0 ? 'true' : 'false'}
                                    tabindex={tabIndex === 0 ? 0 : -1}
                                    data-case-tab
                                  >
                                    <span>{String(tabIndex + 1).padStart(2, '0')}</span>
                                    {tab.label}
                                  </button>
                                ))}
                              </div>

                              {block.tabs.map((tab, tabIndex) => (
                                <div
                                  id={`${section.id}-${tab.id}-panel`}
                                  class:list={['case-tabs__panel', tabIndex === 0 && 'is-active']}
                                  role="tabpanel"
                                  aria-labelledby={`${section.id}-${tab.id}-tab`}
                                  hidden={tabIndex !== 0}
                                  data-case-tab-panel
                                >
                                  <h3>{tab.title}</h3>
                                  {tab.text && (
                                    <p class="case-tabs__intro">
                                      {highlightTextParts(tab.text).map((part) =>
                                        part.highlight ? <strong class="case-text-highlight">{part.text}</strong> : part.text,
                                      )}
                                    </p>
                                  )}

                                  {tab.featureItems && tab.evidence && (
                                    <div class="case-tab-feature">
                                      <div class="case-feature__cards">
                                        {tab.featureItems.map((item) => (
                                          <article class:list={[item.tone && `case-story-card--${item.tone}`]}>
                                            <strong>{item.label}</strong>
                                            <p>
                                              {highlightTextParts(item.text).map((part) =>
                                                part.highlight ? <strong class="case-text-highlight">{part.text}</strong> : part.text,
                                              )}
                                            </p>
                                          </article>
                                        ))}
                                      </div>
                                      <figure class="case-evidence case-evidence--device">
                                        <div class="case-evidence__browser" aria-hidden="true">
                                          <span></span><span></span><span></span>
                                        </div>
                                        <div class="case-evidence__frame" aria-hidden="true">
                                          <i></i>
                                          <i></i>
                                          <i></i>
                                        </div>
                                        <figcaption>
                                          <strong>{tab.evidence.label}</strong>
                                          {tab.evidence.caption && <span>{tab.evidence.caption}</span>}
                                        </figcaption>
                                      </figure>
                                    </div>
                                  )}

                                  {tab.flow && (
                                    <ol class="case-flow case-flow--deck" aria-label={`${tab.title} 처리 흐름`}>
                                      {tab.flow.map((step, flowIndex) => (
                                        <li>
                                          <span>{String(flowIndex + 1).padStart(2, '0')}</span>
                                          <strong>{step}</strong>
                                        </li>
                                      ))}
                                    </ol>
                                  )}

                                  {tab.hierarchy && (
                                    <div class="case-hierarchy case-hierarchy--deck">
                                      <strong class="case-hierarchy__parent">{tab.hierarchy.parent}</strong>
                                      <div class="case-hierarchy__children">
                                        {tab.hierarchy.items.map((item) => (
                                          <article class:list={[item.tone && `is-${item.tone}`]}>
                                            <span>{item.label}</span>
                                            <strong>{item.value}</strong>
                                          </article>
                                        ))}
                                      </div>
                                      <p>{tab.hierarchy.footer}</p>
                                    </div>
                                  )}

                                  {tab.cards && (
                                    <div class="case-content-group case-content-group--deck">
                                      {tab.cards.label && <h4>{tab.cards.label}</h4>}
                                      <div
                                        class:list={[
                                          'case-blocks',
                                          'case-story-cards',
                                          `case-story-cards--${tab.cards.columns ?? 3}`,
                                        ]}
                                      >
                                        {tab.cards.items.map((item) => (
                                          <article class:list={[item.tone && `case-story-card--${item.tone}`]}>
                                            <span>{item.label}</span>
                                            <p>
                                              {highlightTextParts(item.text).map((part) =>
                                                part.highlight ? <strong class="case-text-highlight">{part.text}</strong> : part.text,
                                              )}
                                            </p>
                                          </article>
                                        ))}
                                      </div>
                                    </div>
                                  )}

                                  {tab.comparison && (
                                    <div class="case-comparison">
                                      <table>
                                        <thead>
                                          <tr>
                                            <th scope="col">비교 항목</th>
                                            {tab.comparison.columns.map((column, columnIndex) => (
                                              <th
                                                scope="col"
                                                class={columnIndex === tab.comparison?.highlightColumn ? 'is-highlighted' : undefined}
                                              >
                                                {column}
                                              </th>
                                            ))}
                                          </tr>
                                        </thead>
                                        <tbody>
                                          {tab.comparison.rows.map((row) => (
                                            <tr>
                                              <th scope="row">{row.label}</th>
                                              {row.values.map((value, columnIndex) => (
                                                <td
                                                  class={columnIndex === tab.comparison?.highlightColumn ? 'is-highlighted' : undefined}
                                                >
                                                  {value}
                                                </td>
                                              ))}
                                            </tr>
                                          ))}
                                        </tbody>
                                      </table>
                                    </div>
                                  )}

                                  {tab.callout && (
                                    <aside class:list={['case-tab-callout', `is-${tab.calloutTone ?? 'dark'}`]}>
                                      {highlightTextParts(tab.callout).map((part) =>
                                        part.highlight ? <strong class="case-text-highlight">{part.text}</strong> : part.text,
                                      )}
                                    </aside>
                                  )}

                                  {tab.supportCards && (
                                    <div class="case-tab-support">
                                      {tab.supportCards.map((support) => (
                                        <article>
                                          {support.image && (
                                            <figure class="case-tab-support__image">
                                              <img src={support.image.src} alt={support.image.alt} loading="lazy" />
                                            </figure>
                                          )}
                                          <h4>{support.title}</h4>
                                          {support.text && <p>{support.text}</p>}
                                          <dl>
                                            {support.items.map((item) => (
                                              <div>
                                                <dt>{item.label}</dt>
                                                <dd>{item.value}</dd>
                                              </div>
                                            ))}
                                          </dl>
                                        </article>
                                      ))}
                                    </div>
                                  )}

                                  {tab.accordions && (
                                    <div class="case-accordions">
                                      {tab.accordions.map((item) => (
                                        <details>
                                          <summary>
                                            <span>{item.title}</span>
                                            <i aria-hidden="true">+</i>
                                          </summary>
                                          <div class="case-accordion__body">
                                            {item.text && <p>{item.text}</p>}
                                            {item.image && (
                                              <figure class="case-accordion__image">
                                                <img src={item.image.src} alt={item.image.alt} loading="lazy" />
                                              </figure>
                                            )}
                                            {item.cards && (
                                              <div class="case-accordion__cards">
                                                {item.cards.map((card) => (
                                                  <article>
                                                    <strong>{card.label}</strong>
                                                    <p>{card.text}</p>
                                                  </article>
                                                ))}
                                              </div>
                                            )}
                                            {item.facts && (
                                              <dl class="case-accordion__facts">
                                                {item.facts.map((fact) => (
                                                  <div>
                                                    <dt>{fact.label}</dt>
                                                    <dd>{fact.value}</dd>
                                                  </div>
                                                ))}
                                              </dl>
                                            )}
                                          </div>
                                        </details>
                                      ))}
                                    </div>
                                  )}
                                </div>
                              ))}
                            </div>
                          )}

                          {block.type === 'video' && (
                            <div class="case-demo" data-demo-ready={block.src ? 'true' : 'false'}>
                              {block.src ? (
                                <video controls poster={block.poster} class="case-demo-video" preload="metadata">
                                  <source src={block.src} type={block.mimeType ?? 'video/mp4'} />
                                  브라우저가 비디오 재생을 지원하지 않습니다.
                                </video>
                              ) : (
                                <div class="case-demo__placeholder" role="status">
                                  <span aria-hidden="true">▶</span>
                                  <div>
                                    <strong>{block.title}</strong>
                                    <p>{block.description}</p>
                                  </div>
                                </div>
                              )}
                            </div>
                          )}

                          {block.type === 'callout' && (
                            <aside class="case-callout" data-block-label={block.label}>
                              {block.label && <span>{block.label}</span>}
                              <p>{block.text}</p>
                            </aside>
                          )}
                        </>
                      ))}
                    </div>
                  )}

                  {!section.content && section.facts && (
                    <dl class="case-facts">
                      {section.facts.map((fact) => (
                        <div>
                          <dt>{fact.label}</dt>
                          <dd>{fact.value}</dd>
                        </div>
                      ))}
                    </dl>
                  )}

                  {!section.content && section.flow && (
                    <ol class="case-flow" aria-label={`${section.title} 처리 흐름`}>
                      {section.flow.map((step, flowIndex) => (
                        <li>
                          <span>{String(flowIndex + 1).padStart(2, '0')}</span>
                          <strong>{step}</strong>
                        </li>
                      ))}
                    </ol>
                  )}

                  {!section.content && section.states && (
                    <dl class="case-states">
                      {section.states.map((state) => (
                        <div>
                          <dt>{state.label}</dt>
                          <dd>{state.value}</dd>
                        </div>
                      ))}
                    </dl>
                  )}

                  {!section.content && section.blocks && (
                    <div class="case-blocks">
                      {section.blocks.map((block) => (
                        <article>
                          <span>{block.label}</span>
                          <p>{block.text}</p>
                        </article>
                      ))}
                    </div>
                  )}

                  {!section.content && section.metrics && (
                    <div class="case-metrics">
                      {section.metrics.map((metric) => (
                        <article class:list={[metric.tone && `case-metric--${metric.tone}`]}>
                          <span>{metric.label}</span>
                          <strong>{metric.value}</strong>
                          {metric.note && <small>{metric.note}</small>}
                        </article>
                      ))}
                    </div>
                  )}

                  {!section.content && section.bullets && section.id !== 'result' && (
                    <ul class="case-points">
                      {section.bullets.map((bullet) => <li>{bullet}</li>)}
                    </ul>
                  )}

                  {!section.content && section.bullets && section.id === 'result' && (
                    <div class="case-result">
                      <article>
                        <span>RESULT</span>
                        <ul>
                          {section.bullets.slice(0, 2).map((bullet) => <li>{bullet}</li>)}
                        </ul>
                      </article>
                      <article>
                        <span>LEARNED</span>
                        <ul>
                          {section.bullets.slice(2).map((bullet) => <li>{bullet}</li>)}
                        </ul>
                      </article>
                    </div>
                  )}
                </div>
              </section>
            );
          })
        }
      </div>
    </div>
  </main>

  <div class="pointer-dot" aria-hidden="true"></div>

  <script>
    const deck = document.querySelector<HTMLElement>('[data-case-deck]');
    const sections = [...document.querySelectorAll<HTMLElement>('[data-case-section]')];
    const tocLinks = [...document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]')];
    const toc = document.querySelector<HTMLElement>('.case-study__toc');
    const progress = document.querySelector<HTMLElement>('[data-case-progress]');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const finePointer = window.matchMedia('(pointer: fine)');
    const desktopLayout = window.matchMedia('(min-width: 721px)');
    const chapterDeck = deck?.dataset.scrollMode === 'chapter';

    window.scrollTo(0, 0);

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const activeIndex = sections.indexOf(entry.target as HTMLElement);
          const activeId = (entry.target as HTMLElement).id;

          (entry.target as HTMLElement).classList.add('has-entered');
          sections.forEach((section) => section.classList.toggle('is-active', section.id === activeId));
          tocLinks.forEach((link) => link.classList.toggle('is-active', link.hash === `#${activeId}`));
          if (progress && activeIndex >= 0) {
            progress.textContent = String(activeIndex + 1).padStart(2, '0');
          }
        });
      },
      { root: deck, rootMargin: '-22% 0px -62% 0px', threshold: 0 },
    );

    if (!chapterDeck) {
      sections.forEach((section) => observer.observe(section));
    }

    if (deck) {
      let wheelTotal = 0;
      let wheelReset: number | undefined;
      let isChangingSection = false;
      let changeReset: number | undefined;

      const setActiveSection = (index: number) => {
        const activeIndex = Math.max(0, Math.min(sections.length - 1, index));
        const target = sections[activeIndex];
        if (!target) return;

        target.classList.add('has-entered');
        sections.forEach((section, sectionIndex) => {
          section.classList.toggle('is-active', sectionIndex === activeIndex);
        });
        tocLinks.forEach((link, linkIndex) => {
          link.classList.toggle('is-active', linkIndex === activeIndex);
        });
        if (!desktopLayout.matches && toc) {
          const activeLink = tocLinks[activeIndex];
          if (activeLink) {
            toc.scrollTo({
              left: Math.max(0, activeLink.offsetLeft - (toc.clientWidth - activeLink.clientWidth) / 2),
              behavior: reducedMotion.matches ? 'auto' : 'smooth',
            });
          }
        }
        if (progress) {
          progress.textContent = String(activeIndex + 1).padStart(2, '0');
        }
      };

      const activeSectionIndex = () => {
        const activeIndex = sections.findIndex((section) => section.classList.contains('is-active'));
        if (activeIndex >= 0) return activeIndex;

        return sections.reduce((nearestIndex, section, index) => {
          const sectionDistance = Math.abs(section.offsetTop - deck.scrollTop);
          const nearestDistance = Math.abs(sections[nearestIndex].offsetTop - deck.scrollTop);
          return sectionDistance < nearestDistance ? index : nearestIndex;
        }, 0);
      };

      const moveToSection = (index: number) => {
        const target = sections[Math.max(0, Math.min(sections.length - 1, index))];
        if (!target) return;

        isChangingSection = true;
        if (chapterDeck) {
          const targetIndex = sections.indexOf(target);
          setActiveSection(targetIndex);
          deck.scrollTo({ top: 0, behavior: 'auto' });
          window.history.replaceState(null, '', `#${target.id}`);

          window.clearTimeout(changeReset);
          changeReset = window.setTimeout(() => {
            isChangingSection = false;
          }, reducedMotion.matches ? 0 : 220);
          return;
        }

        const deckPaddingTop = parseFloat(getComputedStyle(deck).paddingTop);
        deck.scrollTo({
          top: Math.max(0, target.offsetTop - deckPaddingTop),
          behavior: reducedMotion.matches ? 'auto' : 'smooth',
        });

        window.clearTimeout(changeReset);
        changeReset = window.setTimeout(() => {
          isChangingSection = false;
        }, reducedMotion.matches ? 80 : 760);
      };

      deck.addEventListener(
        'wheel',
        (event) => {
          if (!desktopLayout.matches || event.ctrlKey) return;

          if (chapterDeck) {
            const currentSection = sections[activeSectionIndex()];
            const direction = event.deltaY > 0 ? 1 : -1;
            const maxSectionScroll = currentSection
              ? currentSection.scrollHeight - currentSection.clientHeight
              : 0;
            const canScrollWithinSection =
              currentSection &&
              (direction > 0
                ? currentSection.scrollTop < maxSectionScroll - 2
                : currentSection.scrollTop > 2);

            if (canScrollWithinSection) {
              wheelTotal = 0;
              return;
            }

            event.preventDefault();
            if (isChangingSection) return;

            wheelTotal += event.deltaY;
            window.clearTimeout(wheelReset);
            wheelReset = window.setTimeout(() => {
              wheelTotal = 0;
            }, 180);

            if (Math.abs(wheelTotal) < 64) return;

            const chapterDirection = wheelTotal > 0 ? 1 : -1;
            wheelTotal = 0;
            moveToSection(activeSectionIndex() + chapterDirection);
            return;
          }

          if (reducedMotion.matches) return;
          if (isChangingSection) {
            event.preventDefault();
            return;
          }

          const currentIndex = activeSectionIndex();
          const currentSection = sections[currentIndex];
          const direction = event.deltaY > 0 ? 1 : -1;
          const sectionTop = currentSection?.offsetTop ?? 0;
          const sectionBottom = sectionTop + (currentSection?.offsetHeight ?? 0);
          const viewportBottom = deck.scrollTop + deck.clientHeight;
          const canScrollWithinSection =
            direction > 0
              ? viewportBottom < sectionBottom - 2
              : deck.scrollTop > sectionTop + 2;

          if (canScrollWithinSection) {
            wheelTotal = 0;
            return;
          }

          event.preventDefault();
          wheelTotal += event.deltaY;
          window.clearTimeout(wheelReset);
          wheelReset = window.setTimeout(() => {
            wheelTotal = 0;
          }, 140);

          if (Math.abs(wheelTotal) < 18) return;

          const jumpDirection = wheelTotal > 0 ? 1 : -1;
          wheelTotal = 0;
          moveToSection(currentIndex + jumpDirection);
        },
        { passive: false },
      );

      deck.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((link) => {
        link.addEventListener('click', (event) => {
          const targetId = link.hash.slice(1);
          const targetIndex = sections.findIndex((section) => section.id === targetId);
          if (targetIndex < 0) return;

          event.preventDefault();
          moveToSection(targetIndex);
        });
      });

      if (chapterDeck) {
        const initialIndex = sections.findIndex((section) => `#${section.id}` === window.location.hash);
        setActiveSection(initialIndex >= 0 ? initialIndex : 0);
        deck.scrollTo({ top: 0, behavior: 'auto' });

        window.addEventListener('hashchange', () => {
          const hashIndex = sections.findIndex((section) => `#${section.id}` === window.location.hash);
          if (hashIndex >= 0) {
            setActiveSection(hashIndex);
            deck.scrollTo({ top: 0, behavior: 'auto' });
          }
        });

        window.addEventListener('keydown', (event) => {
          if (
            event.altKey ||
            event.ctrlKey ||
            event.metaKey ||
            (event.target as HTMLElement).closest('a, button, input, textarea, select')
          ) {
            return;
          }

          const nextKeys = ['ArrowRight', 'ArrowDown', 'PageDown'];
          const previousKeys = ['ArrowLeft', 'ArrowUp', 'PageUp'];
          if (!nextKeys.includes(event.key) && !previousKeys.includes(event.key)) return;

          event.preventDefault();
          moveToSection(activeSectionIndex() + (nextKeys.includes(event.key) ? 1 : -1));
        });
      }
    }

    document.querySelectorAll<HTMLElement>('[data-case-tabs]').forEach((tabGroup) => {
      const tabButtons = [...tabGroup.querySelectorAll<HTMLButtonElement>('[data-case-tab]')];
      const tabPanels = [...tabGroup.querySelectorAll<HTMLElement>('[data-case-tab-panel]')];

      const activateTab = (index: number) => {
        tabButtons.forEach((button, buttonIndex) => {
          const isActive = buttonIndex === index;
          button.setAttribute('aria-selected', String(isActive));
          button.tabIndex = isActive ? 0 : -1;
        });
        tabPanels.forEach((panel, panelIndex) => {
          const isActive = panelIndex === index;
          panel.hidden = !isActive;
          panel.classList.toggle('is-active', isActive);
        });
      };

      tabButtons.forEach((button, index) => {
        button.addEventListener('click', () => activateTab(index));
      });
    });

    const pointerDot = document.querySelector<HTMLElement>('.pointer-dot');
    let pointerX = window.innerWidth / 2;
    let pointerY = window.innerHeight / 2;
    let renderedX = pointerX;
    let renderedY = pointerY;

    const renderPointer = () => {
      renderedX += (pointerX - renderedX) * 0.16;
      renderedY += (pointerY - renderedY) * 0.16;
      pointerDot?.style.setProperty('transform', `translate3d(${renderedX}px, ${renderedY}px, 0)`);
      requestAnimationFrame(renderPointer);
    };

    if (finePointer.matches && !reducedMotion.matches) {
      document.documentElement.classList.add('has-custom-pointer');
      window.addEventListener('pointermove', (event) => {
        pointerX = event.clientX;
        pointerY = event.clientY;
      });
      renderPointer();
    }

    document.querySelectorAll<HTMLElement>('.magnetic').forEach((element) => {
      element.addEventListener('pointermove', (event) => {
        if (reducedMotion.matches) return;
        const rect = element.getBoundingClientRect();
        const x = (event.clientX - rect.left - rect.width / 2) * 0.12;
        const y = (event.clientY - rect.top - rect.height / 2) * 0.12;
        element.style.transform = `translate3d(${x}px, ${y}px, 0)`;
      });
      element.addEventListener('pointerleave', () => {
        element.style.transform = '';
      });
    });

    const rippleLayer = document.querySelector<HTMLElement>('.ripple-layer');
    document.addEventListener('pointerdown', (event) => {
      if (reducedMotion.matches || !rippleLayer) return;
      const ripple = document.createElement('span');
      ripple.className = 'click-ripple';
      ripple.style.left = `${event.clientX}px`;
      ripple.style.top = `${event.clientY}px`;
      rippleLayer.append(ripple);
      ripple.addEventListener('animationend', () => ripple.remove(), { once: true });
    });
  </script>
</BaseLayout>
