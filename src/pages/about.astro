---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<BaseLayout
  title="About - 정호진"
  description="필요한 범위에서 직접 시도하고, 결과가 의도한 흐름으로 이어지는지 확인하며 경험을 쌓아가는 백엔드 개발자 정호진을 소개합니다."
  bodyClass="document-page about-page-body"
>
  <SiteHeader />

  <main class="about-page" aria-labelledby="about-title">
    <section class="about-hero">
      <div class="about-hero__copy">
        <p class="about-hero__label"><span aria-hidden="true"></span>ABOUT</p>
        <h1 id="about-title">
          <span>배우고, 시도하며,</span>
          <span><strong>경험</strong>을 쌓아갑니다.</span>
        </h1>
        <p class="about-hero__description">
          필요한 내용을 프로젝트에 적용하고,<br />
          의도한 흐름으로 동작하는지 확인해왔습니다.
        </p>
      </div>

      <div class="about-visual" aria-hidden="true">
        <img src="/about-hero-visual.png" alt="" decoding="async" />
      </div>
    </section>

    <section class="about-summary" aria-label="About summary">
      <div class="about-summary__grid">
        <article class="about-summary__item">
          <span class="about-summary__index">01</span>
          <span class="about-summary__rule" aria-hidden="true"></span>
          <span class="about-summary__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
              <circle cx="11" cy="11" r="7"></circle>
              <path d="m16.5 16.5 4 4"></path>
            </svg>
          </span>
          <div class="about-summary__copy">
            <h2>중요하게 생각하는 점</h2>
            <p>
              프로젝트를 진행하며 더 알아야 할 부분을 살피고, 필요한 내용을 배우며
              경험의 범위를 넓혀왔습니다.
            </p>
          </div>
        </article>

        <article class="about-summary__item">
          <span class="about-summary__index">02</span>
          <span class="about-summary__rule" aria-hidden="true"></span>
          <span class="about-summary__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
              <path d="M8.5 4.75h3.15a2.2 2.2 0 1 1 4.2 0h3.4v5.15a2.2 2.2 0 1 1 0 4.2v5.15H5.75v-4.9h1.7a2.1 2.1 0 1 0 0-4.2h-1.7v-5.4H8.5Z"></path>
            </svg>
          </span>
          <div class="about-summary__copy">
            <h2>경험을 넓힌 방식</h2>
            <p>
              익숙하지 않은 영역도 필요한 범위에서 시도해보았습니다. 결과는 요구사항과
              서비스 흐름에 맞는지 확인하며 다듬었습니다.
            </p>
          </div>
        </article>

        <article class="about-summary__item">
          <span class="about-summary__index">03</span>
          <span class="about-summary__rule" aria-hidden="true"></span>
          <span class="about-summary__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img">
              <path d="M3 17 9 11l4 4 8-8"></path>
              <path d="M15 7h6v6"></path>
            </svg>
          </span>
          <div class="about-summary__copy">
            <h2>현재 방향</h2>
            <p>
              기능 구현 경험을 바탕으로, 성능과 데이터 정합성, 운영 환경까지 학습 범위를
              넓혀가고 있습니다.
            </p>
          </div>
        </article>
      </div>

      <a class="about-next magnetic" href="/capabilities" aria-label="Capabilities 페이지로 이동">
        <span>CAPABILITIES</span>
        <i aria-hidden="true">↗</i>
      </a>
    </section>
  </main>

  <script>
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    document.querySelectorAll<HTMLElement>('.magnetic').forEach((element) => {
      element.addEventListener('pointermove', (event) => {
        if (reducedMotion.matches) return;
        const rect = element.getBoundingClientRect();
        const strength = Number(element.dataset.magneticStrength ?? 0.12);
        const x = (event.clientX - rect.left - rect.width / 2) * strength;
        const y = (event.clientY - rect.top - rect.height / 2) * strength;
        element.style.transform = `translate3d(${x}px, ${y}px, 0)`;
      });
      element.addEventListener('pointerleave', () => {
        element.style.transform = '';
      });
    });
  </script>
</BaseLayout>
