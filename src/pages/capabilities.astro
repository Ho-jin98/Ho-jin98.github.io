---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { capabilities } from '../data/portfolio';
---

<BaseLayout
  title="Capabilities — 정호진"
  description="직접 구현하고 테스트한 범위를 중심으로 정리한 백엔드 개발 역량입니다."
  bodyClass="document-page"
>
  <SiteHeader />

  <main class="capabilities-page">
    <header class="capabilities-page__intro">
      <div class="section-index mono-label">
        <span>CAPABILITIES</span>
        <span>IMPLEMENTED & TESTED</span>
      </div>
      <div>
        <h1>기술보다 먼저,<br /><span>선택의 이유</span>를 봅니다.</h1>
        <p>팀 전체 기술이 아닌, 직접 구현하고 테스트한 범위를 기준으로 정리했습니다.</p>
      </div>
    </header>

    <section class="capability-page-list">
      {capabilities.map((capability) => (
        <article>
          <span class="capability-page-list__number">{capability.number}</span>
          <div class="capability-page-list__content">
            <h2>{capability.title}</h2>
            <p>{capability.description}</p>
            <p class="capability-page-list__tech">{capability.items}</p>
          </div>
        </article>
      ))}
    </section>

    <a class="page-next-link" href="/#contact">
      <span>NEXT</span>
      CONTACT →
    </a>
  </main>
</BaseLayout>
