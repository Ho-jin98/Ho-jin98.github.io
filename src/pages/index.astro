---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectShowcase from '../components/ProjectShowcase.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { profile, projects } from '../data/portfolio';
---

<BaseLayout
  title="정호진 — Backend Engineer"
  description="낯선 기술을 빠르게 익히고 실제 서비스 흐름에 적용해온 백엔드 개발자 정호진의 포트폴리오입니다."
>
  <SiteHeader />

  <main class="scroll-deck" data-scroll-deck>
    <section id="home" class="panel panel--hero is-active" data-panel aria-labelledby="hero-title">
      <div class="hero-meta mono-label">
        <span>BACKEND</span>
      </div>

      <div class="hero-copy">
        <p class="eyebrow">BUILDING RELIABLE SERVICE FLOWS</p>
        <h1 id="hero-title">
          <span>안녕하세요<em>!</em></span>
        </h1>
        <p class="hero-description">
          {profile.introduction.map((line) => <span>{line}</span>)}
        </p>
      </div>

      <div class="hero-orbit" aria-hidden="true">
        <div class="orbit-box"></div>
        <div class="orbit-line orbit-line--x"></div>
        <div class="orbit-line orbit-line--y"></div>
        <div class="orbit-circle"></div>
        <div class="orbit-node cursor-reactive"></div>
      </div>

      <a class="drag-cue magnetic" href="#hankkipot">
        <span class="drag-cue__circle">↓</span>
        <span>
          SCROLL TO EXPLORE
          <small>01 — 05</small>
        </span>
      </a>
    </section>

    {projects.map((project) => <ProjectShowcase project={project} />)}

    <section id="contact" class="panel panel--contact" data-panel aria-labelledby="contact-title">
      <div class="section-index mono-label">
        <span>05</span>
        <span>CONTACT</span>
      </div>

      <div class="contact-copy">
        <div class="contact-intro">
          <p>
            새로운 문제를 만나고,<br />
            함께 해결해나갈 기회를 기다리고 있습니다.<br />
            <br />
            작은 역할부터 책임감 있게 맡아,<br />
            팀에 필요한 흐름을 만들어가겠습니다.
          </p>
          <div class="contact-quick-actions" aria-label="빠른 연락">
            <a class="contact-quick-action contact-quick-action--primary magnetic" href={`mailto:${profile.email}`}>
              SEND EMAIL <i>→</i>
            </a>
            <a
              class="contact-quick-action contact-quick-action--secondary magnetic"
              href={profile.github}
              target="_blank"
              rel="noreferrer"
            >
              VIEW GITHUB <i>↗</i>
            </a>
          </div>
        </div>
        <h2 id="contact-title">READY TO <span>GROW.</span></h2>
      </div>

      <div class="contact-actions">
        <a class="contact-link magnetic" href={`mailto:${profile.email}`}>
          <span>EMAIL</span>
          <strong>{profile.email}</strong>
          <i>↗</i>
        </a>
        <a class="contact-link magnetic" href={profile.github} target="_blank" rel="noreferrer">
          <span>GITHUB</span>
          <strong>github.com/Ho-jin98</strong>
          <i>↗</i>
        </a>
        {
          profile.blog ? (
            <a class="contact-link magnetic" href={profile.blog} target="_blank" rel="noreferrer">
              <span>BLOG</span>
              <strong>hojin98.tistory.com</strong>
              <i>↗</i>
            </a>
          ) : (
            <div class="contact-link contact-link--placeholder" aria-label="블로그 주소 준비 중">
              <span>BLOG</span>
              <strong>COMING SOON</strong>
              <i>—</i>
            </div>
          )
        }
      </div>

      <footer>
        <span>© 2026 {profile.nameEn}</span>
      </footer>
    </section>
  </main>

  <aside class="panel-progress" aria-label="현재 섹션">
    <span class="panel-progress__line"></span>
    <a href="#home" class="is-current" aria-label="홈"><i></i><span>01</span></a>
    <a href="#hankkipot" aria-label="한끼팟"><i></i><span>02</span></a>
    <a href="#k-server" aria-label="K-server"><i></i><span>03</span></a>
    <a href="#readys7" aria-label="Ready's7"><i></i><span>04</span></a>
    <a href="#contact" aria-label="연락처"><i></i><span>05</span></a>
  </aside>

  <div class="pointer-dot" aria-hidden="true"></div>

  <script>
    const deck = document.querySelector<HTMLElement>('[data-scroll-deck]');
    const panels = [...document.querySelectorAll<HTMLElement>('[data-panel]')];
    const progressLinks = [...document.querySelectorAll<HTMLAnchorElement>('.panel-progress a')];
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const finePointer = window.matchMedia('(pointer: fine)');

    if (deck) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;

            panels.forEach((panel) => panel.classList.toggle('is-active', panel === entry.target));
            progressLinks.forEach((link) => {
              link.classList.toggle('is-current', link.hash === `#${entry.target.id}`);
            });
          });
        },
        { root: deck, threshold: 0.55 },
      );

      panels.forEach((panel) => observer.observe(panel));

      let pointerId: number | null = null;
      let dragStartY = 0;
      let dragStartScroll = 0;
      let hasDragged = false;

      deck.addEventListener('pointerdown', (event) => {
        if (
          !finePointer.matches ||
          event.button !== 0 ||
          (event.target as HTMLElement).closest('a, button, input, textarea')
        ) {
          return;
        }

        pointerId = event.pointerId;
        dragStartY = event.clientY;
        dragStartScroll = deck.scrollTop;
        hasDragged = false;
        deck.setPointerCapture(pointerId);
        deck.classList.add('is-dragging');
      });

      deck.addEventListener('pointermove', (event) => {
        if (pointerId !== event.pointerId) return;
        const distance = event.clientY - dragStartY;
        hasDragged ||= Math.abs(distance) > 5;
        deck.scrollTop = dragStartScroll - distance * 1.25;
      });

      const releaseDrag = (event: PointerEvent) => {
        if (pointerId !== event.pointerId) return;
        if (deck.hasPointerCapture(pointerId)) deck.releasePointerCapture(pointerId);
        pointerId = null;
        deck.classList.remove('is-dragging');

        if (hasDragged && !reducedMotion.matches) {
          const nearest = panels.reduce((closest, panel) => {
            const panelDistance = Math.abs(panel.offsetTop - deck.scrollTop);
            const closestDistance = Math.abs(closest.offsetTop - deck.scrollTop);
            return panelDistance < closestDistance ? panel : closest;
          });
          nearest.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      };

      deck.addEventListener('pointerup', releaseDrag);
      deck.addEventListener('pointercancel', releaseDrag);
    }

    const pointerDot = document.querySelector<HTMLElement>('.pointer-dot');
    const orbitCircle = document.querySelector<HTMLElement>('.orbit-circle');
    const orbitNode = document.querySelector<HTMLElement>('.orbit-node');
    let pointerX = window.innerWidth / 2;
    let pointerY = window.innerHeight / 2;
    let renderedX = pointerX;
    let renderedY = pointerY;

    const updateOrbitNode = (clientX: number, clientY: number) => {
      if (!orbitCircle || !orbitNode) return;

      let normalizedX = (clientX - window.innerWidth / 2) / (window.innerWidth / 2);
      let normalizedY = (clientY - window.innerHeight / 2) / (window.innerHeight / 2);
      const distance = Math.hypot(normalizedX, normalizedY);

      if (distance > 1) {
        normalizedX /= distance;
        normalizedY /= distance;
      }

      const circleRadius = orbitCircle.getBoundingClientRect().width / 2;
      const nodeRadius = orbitNode.getBoundingClientRect().width / 2;
      const travelRadius = Math.max(0, circleRadius - nodeRadius - 3);

      orbitNode.style.setProperty('--orbit-x', `${normalizedX * travelRadius}px`);
      orbitNode.style.setProperty('--orbit-y', `${normalizedY * travelRadius}px`);
    };

    const renderPointer = () => {
      renderedX += (pointerX - renderedX) * 0.16;
      renderedY += (pointerY - renderedY) * 0.16;
      pointerDot?.style.setProperty('transform', `translate3d(${renderedX}px, ${renderedY}px, 0)`);
      requestAnimationFrame(renderPointer);
    };

    if (finePointer.matches && !reducedMotion.matches) {
      document.documentElement.classList.add('has-custom-pointer');
      window.addEventListener('pointermove', (event) => {
        pointerX = event.clientX;
        pointerY = event.clientY;
        updateOrbitNode(event.clientX, event.clientY);
      });
      window.addEventListener('resize', () => updateOrbitNode(pointerX, pointerY));
      updateOrbitNode(pointerX, pointerY);
      renderPointer();
    }

    document.querySelectorAll<HTMLElement>('.magnetic').forEach((element) => {
      element.addEventListener('pointermove', (event) => {
        if (reducedMotion.matches) return;
        const rect = element.getBoundingClientRect();
        const x = (event.clientX - rect.left - rect.width / 2) * 0.12;
        const y = (event.clientY - rect.top - rect.height / 2) * 0.12;
        element.style.transform = `translate3d(${x}px, ${y}px, 0)`;
      });
      element.addEventListener('pointerleave', () => {
        element.style.transform = '';
      });
    });

    const rippleLayer = document.querySelector<HTMLElement>('.ripple-layer');
    document.addEventListener('pointerdown', (event) => {
      if (reducedMotion.matches || !rippleLayer) return;

      const ripple = document.createElement('span');
      ripple.className = 'click-ripple';
      ripple.style.left = `${event.clientX}px`;
      ripple.style.top = `${event.clientY}px`;
      rippleLayer.append(ripple);
      ripple.addEventListener('animationend', () => ripple.remove(), { once: true });
    });
  </script>
</BaseLayout>
