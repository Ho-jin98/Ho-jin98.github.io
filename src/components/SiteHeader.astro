---
const isProjectPage = Astro.url.pathname.startsWith('/work/');
const isWorkPage = Astro.url.pathname === '/' || isProjectPage;
---

<header class="site-header">
  <a class="wordmark magnetic" href="/" aria-label="첫 화면으로 이동">
    HOJIN<span class="wordmark-dot">.</span>
  </a>

  <nav class="desktop-nav" aria-label="주요 메뉴">
    <a class:list={['magnetic', isWorkPage && 'is-active']} href="/#hankkipot">WORK</a>
    <a class="magnetic" href="/about">ABOUT</a>
    <a class="magnetic" href="/capabilities">CAPABILITIES</a>
    <a class="magnetic" href="/#contact">CONTACT</a>
  </nav>

  <button class="menu-button" type="button" aria-expanded="false" aria-controls="mobile-menu">
    <span class="sr-only">메뉴 열기</span>
    <span></span>
    <span></span>
  </button>

  <nav id="mobile-menu" class="mobile-menu" aria-label="모바일 메뉴" hidden>
    <a href="/#hankkipot">WORK</a>
    <a href="/about">ABOUT</a>
    <a href="/capabilities">CAPABILITIES</a>
    <a href="/#contact">CONTACT</a>
  </nav>
</header>

<script>
  const menuButton = document.querySelector<HTMLButtonElement>('.menu-button');
  const mobileMenu = document.querySelector<HTMLElement>('#mobile-menu');

  menuButton?.addEventListener('click', () => {
    const isOpen = menuButton.getAttribute('aria-expanded') === 'true';
    menuButton.setAttribute('aria-expanded', String(!isOpen));
    menuButton.classList.toggle('is-open', !isOpen);
    if (mobileMenu) mobileMenu.hidden = isOpen;
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.hidden = true;
      menuButton?.setAttribute('aria-expanded', 'false');
      menuButton?.classList.remove('is-open');
    });
  });
</script>
